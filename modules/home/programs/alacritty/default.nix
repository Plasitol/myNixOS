{ config, pkgs, ... }:

{
  programs.alacritty = {
    enable = true;

    settings = {
      window = {
        # Отключаем заголовок окна (то, о чем ты спрашивал ранее)
        decorations = "None";
        
        # Добавляем небольшие внутренние отступы, чтобы текст не прилипал к краям
        padding = {
          x = 12;
          y = 12;
        };
        
        # Делает отступы динамическими при изменении размера окна
        dynamic_padding = true;
        
        # Запуск окна сразу с нужными размерами (опционально)
        dimensions = {
          columns = 100;
          lines = 30;
        };
      };

      scrolling = {
        history = 10000; # Увеличиваем историю прокрутки
        multiplier = 3;  # Скорость прокрутки
      };

      mouse = {
        hide_when_typing = true; # Прятать курсор мыши при печати
      };

      # Цвета и шрифты здесь не указываем — их автоматически сгенерирует Stylix
    };
  };
}
